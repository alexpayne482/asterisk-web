#!/bin/bash

reinstallDeps=${REINSTALL_DEPS:-0}
sourceDir=$(dirname $(readlink -f "$0"))
pushd "$sourceDir" >/dev/null

# Check required tools are available
which python3 >/dev/null || { echo python3 not found; exit; }
which pip3 >/dev/null || { echo pip3 not found; exit; }

# Reinstall dependencies if requested
if [ ${reinstallDeps} -eq 1 ]; then
    echo "Removing existing virtual environment for clean install..."
    rm -rf venv
fi

# Create and activate a python virtual environment
if [ ! -d "venv" ]; then
    echo "Creating virtual environment..."
    python3 -m venv venv || { echo "Failed to create virtual environment"; exit 1; }
fi

# Activate virtual environment and install required packages
source venv/bin/activate
if [ "$(pip freeze -r ./requirements.txt 2>&1 | grep 'not installed')" ]; then
    echo "Installing required packages..."
    pip install -r requirements.txt || { echo "Failed to install required packages"; exit 1; }
fi

# Run script (in original directory context)
popd >/dev/null
if [ "$1" == "test" ]; then
    shift
    python test.py "$@"
else
    python -m asterisk-web "$@"
fi

# Deactivate virtual environment
deactivate